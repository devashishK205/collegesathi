          juniorEmail: email,
          juniorPhone: phone,
          juniorMajor: major,
          collegeId: selectedCollege?.id || 'unknown',
          collegeName: selectedCollege?.name || 'Selected College',
          date: date,
          time: slot,
          topic: notes,
          paymentMethod: paymentMethod,
          amount: amount,
          paymentStatus: paymentStatus,
          bookingStatus: 'pending',
          createdAt: new Date().toISOString()
        };

        // Save to localStorage
        const bookings = JSON.parse(localStorage.getItem('counselBookings') || '[]');
        bookings.push(booking);
        localStorage.setItem('counselBookings', JSON.stringify(bookings));

        // Show success message
        showNotification('🎉 Mentorship session booked successfully! The senior will contact you soon.', 'success');
        
        // Reset form
        hideModal("counselModal");
        ["#coName","#coEmail","#coPhone","#coMajor","#coDate","#coSlot","#coNotes"].forEach(sel=> $(sel).value="");
        $("input[name='paymentMethod'][value='free']").checked = true;

        // Reset button
        submitBtn.innerHTML = originalText;
        submitBtn.disabled = false;
        
        // Reload bookings
        loadBookings();
      }, 1500);
    });

    // Load and display bookings
    function loadBookings() {
      const bookings = JSON.parse(localStorage.getItem('counselBookings') || '[]');
      const container = $("#bookingsContainer");

      if (bookings.length === 0) {
        container.innerHTML = `
          <div class="text-center py-12 text-slate-500">
            <i data-lucide="calendar-x" class="w-16 h-16 mx-auto mb-4 text-slate-300"></i>
            <p class="text-lg font-medium">No sessions booked yet</p>
            <p class="text-sm">Book a mentorship session above to get started!</p>
          </div>
        `;
        return;
      }

      container.innerHTML = '';
      bookings.forEach(booking => {
        const bookingElement = document.createElement('div');
        bookingElement.className = 'rounded-2xl border-2 border-slate-200 p-6 bg-gradient-to-r from-slate-50 to-white';
        
        const statusClass = booking.bookingStatus === 'confirmed' ? 'bg-green-100 text-green-800' : 'bg-amber-100 text-amber-800';
        const paymentStatusClass = booking.paymentStatus === 'paid' ? 'bg-green-100 text-green-800' : 
                                 booking.paymentStatus === 'free' ? 'bg-blue-100 text-blue-800' : 'bg-yellow-100 text-yellow-800';
        
        bookingElement.innerHTML = `
          <div class="flex items-start justify-between mb-4">
            <div>
              <h3 class="text-lg font-semibold text-slate-800">${booking.collegeName}</h3>
              <p class="text-sm text-slate-600">${booking.juniorName} • ${booking.juniorMajor}</p>
            </div>
            <div class="flex gap-2">
              <span class="px-3 py-1 rounded-full text-xs font-semibold ${statusClass}">
                ${booking.bookingStatus.charAt(0).toUpperCase() + booking.bookingStatus.slice(1)}
              </span>
              <span class="px-3 py-1 rounded-full text-xs font-semibold ${paymentStatusClass}">
                ${booking.paymentStatus === 'free' ? 'Free' : booking.paymentStatus.charAt(0).toUpperCase() + booking.paymentStatus.slice(1)}
              </span>
            </div>
          </div>
          
          <div class="grid md:grid-cols-2 gap-4 mb-4">
            <div class="flex items-center gap-2 text-slate-600">
              <i data-lucide="calendar" class="w-4 h-4 text-indigo-500"></i>
              <span class="text-sm">${new Date(booking.date).toLocaleDateString()}</span>
            </div>
            <div class="flex items-center gap-2 text-slate-600">
              <i data-lucide="clock" class="w-4 h-4 text-purple-500"></i>
              <span class="text-sm">${booking.time}</span>
            </div>
            <div class="flex items-center gap-2 text-slate-600">
              <i data-lucide="phone" class="w-4 h-4 text-green-500"></i>
              <span class="text-sm">${booking.juniorPhone}</span>
            </div>
            <div class="flex items-center gap-2 text-slate-600">
              <i data-lucide="credit-card" class="w-4 h-4 text-orange-500"></i>
              <span class="text-sm">${booking.paymentMethod === 'free' ? 'Free Session' : `₹${booking.amount} via ${booking.paymentMethod}`}</span>
            </div>
          </div>
          
          ${booking.topic ? `
            <div class="mb-4">
              <h4 class="text-sm font-semibold text-slate-700 mb-1">Discussion Topics:</h4>
              <p class="text-sm text-slate-600">${booking.topic}</p>
            </div>
          ` : ''}
          
          <div class="flex items-center justify-between pt-4 border-t border-slate-200">
            <span class="text-xs text-slate-500">
              Booked on ${new Date(booking.createdAt).toLocaleDateString()}
            </span>
            <div class="flex gap-2">
              <button onclick="deleteBooking(${booking.id})" class="px-3 py-1.5 rounded-lg border border-red-200 text-red-600 hover:bg-red-50 text-xs font-medium transition-colors">
                <i data-lucide="trash-2" class="w-3 h-3 inline mr-1"></i>Delete
              </button>
              ${booking.paymentStatus === 'pending' && booking.paymentMethod !== 'free' ? `
                <button onclick="processPayment(${booking.id})" class="px-3 py-1.5 rounded-lg bg-green-600 text-white hover:bg-green-700 text-xs font-medium transition-colors">
                  <i data-lucide="credit-card" class="w-3 h-3 inline mr-1"></i>Pay Now
                </button>
              ` : ''}
            </div>
          </div>
        `;
        
        container.appendChild(bookingElement);
      });
      
      // Re-render icons
      window.lucideReady.then(({createIcons}) => createIcons());
    }

    // Delete booking function
    function deleteBooking(bookingId) {
      if (confirm('Are you sure you want to delete this booking? This action cannot be undone.')) {
        const bookings = JSON.parse(localStorage.getItem('counselBookings') || '[]');
        const updatedBookings = bookings.filter(booking => booking.id !== bookingId);
        localStorage.setItem('counselBookings', JSON.stringify(updatedBookings));
        
        showNotification('Booking deleted successfully!', 'success');
        loadBookings();
      }
    }

    // Process payment function
    function processPayment(bookingId) {
      const bookings = JSON.parse(localStorage.getItem('counselBookings') || '[]');
      const booking = bookings.find(b => b.id === bookingId);
      
      if (!booking) return;

      showNotification('Processing payment...', 'success');
      
      setTimeout(() => {
        booking.paymentStatus = 'paid';
        booking.bookingStatus = 'confirmed';
        
        localStorage.setItem('counselBookings', JSON.stringify(bookings));
        showNotification('Payment successful! Your session is now confirmed.', 'success');
        loadBookings();
      }, 2000);
    }

    // Auth (mock)
    $("#openLogin").addEventListener("click", ()=> showModal("authModal"));
    $("#openRegister").addEventListener("click", ()=> showModal("authModal"));
    $("#authAction").addEventListener("click", ()=>{
      currentUser = { name: $("#authName").value || "Guest", role: $("#authRole").value };
      hideModal("authModal");
      alert(`Welcome, ${currentUser.name}! You are logged in as ${currentUser.role}.`);
    });

    // Newsletter (mock subscribe)
    $("#nlBtn").addEventListener("click", ()=>{
      const email = $("#nlEmail").value.trim();
      const msg = $("#nlMsg");
      if(!email || !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)){
        msg.textContent = "Please enter a valid email.";
        msg.className = "mt-2 text-xs text-rose-600";
        return;
      }
      msg.textContent = "Thanks! You’re subscribed.";
      msg.className = "mt-2 text-xs text-emerald-600";
      $("#nlEmail").value = "";
    });

    // Init
    // Back to top button
    const toTop = document.createElement('button');
    toTop.className = 'fixed bottom-6 right-6 hidden md:inline-flex items-center gap-2 btn btn-primary shadow-soft z-40';
    toTop.innerHTML = '<i data-lucide="arrow-up"></i> Top';
    document.body.appendChild(toTop);
    window.addEventListener('scroll', ()=>{
      if(window.scrollY > 400) toTop.classList.remove('hidden'); else toTop.classList.add('hidden');
    });
    toTop.addEventListener('click', ()=> window.scrollTo({ top:0, behavior:'smooth' }));

    // Creative particle effect for hero section
    function createParticles() {
      const hero = document.querySelector('section');
      if (!hero) return;
      
      for (let i = 0; i < 20; i++) {
        const particle = document.createElement('div');
        particle.className = 'absolute w-2 h-2 bg-indigo-400/30 rounded-full';
        particle.style.left = Math.random() * 100 + '%';
        particle.style.top = Math.random() * 100 + '%';
        particle.style.animation = `float ${3 + Math.random() * 4}s ease-in-out infinite`;
        particle.style.animationDelay = Math.random() * 2 + 's';
        hero.appendChild(particle);
      }
    }

    // Creative loading animation
    function showLoading() {
      const loading = document.createElement('div');
      loading.id = 'loading';
      loading.className = 'fixed inset-0 bg-white/90 backdrop-blur-sm z-50 flex items-center justify-center';
      loading.innerHTML = `
        <div class="text-center">
          <div class="w-16 h-16 border-4 border-indigo-200 border-t-indigo-600 rounded-full animate-spin mx-auto mb-4"></div>
          <div class="text-lg font-semibold text-slate-700">Loading amazing colleges...</div>
        </div>
      `;
      document.body.appendChild(loading);
      setTimeout(() => {
        if (loading.parentNode) loading.parentNode.removeChild(loading);
      }, 2000);
    }

    // Creative success notification
    function showNotification(message, type = 'success') {
      const notification = document.createElement('div');
      notification.className = `fixed top-4 right-4 z-50 px-6 py-4 rounded-2xl text-white font-medium shadow-lg transform translate-x-full transition-transform duration-300`;
      
      if (type === 'success') {
        notification.className += ' bg-gradient-to-r from-green-500 to-emerald-500';
      } else if (type === 'error') {
        notification.className += ' bg-gradient-to-r from-red-500 to-rose-500';
      } else {
        notification.className += ' bg-gradient-to-r from-blue-500 to-indigo-500';
      }
      
      notification.textContent = message;
      document.body.appendChild(notification);
      
      setTimeout(() => notification.classList.remove('translate-x-full'), 100);
      setTimeout(() => {
        notification.classList.add('translate-x-full');
        setTimeout(() => notification.remove(), 300);
      }, 3000);
    }

    // Enhanced search with creative suggestions
    function setupSearchSuggestions() {
      const searchInput = document.getElementById('searchInput');
      const suggestions = ['YCCE Nagpur', 'VJTI Mumbai', 'IIT Bombay', 'BITS Pilani', 'NIT Trichy'];
      
      searchInput.addEventListener('focus', () => {
        if (!searchInput.value) {
          let i = 0;
          const typeWriter = () => {
            if (i < suggestions.length) {
              searchInput.placeholder = `Search colleges (e.g., ${suggestions[i]})`;
              i = (i + 1) % suggestions.length;
              setTimeout(typeWriter, 2000);
            }
          };
          typeWriter();
        }
      });
    }

    // Optional: dynamically set WhatsApp link (phone + prefilled message)
    const waLink = document.getElementById('waFab');
    if(waLink){
      const phone = '917999999999'; // change to your number
      const text = encodeURIComponent('Hi! I have a question about College Saathi.');
      waLink.href = `https://wa.me/${phone}?text=${text}`;
    }

    document.addEventListener("DOMContentLoaded", ()=>{
      $("#year").textContent = new Date().getFullYear();
      
      // Show loading animation
      showLoading();
      
      // Initialize creative features
      setTimeout(() => {
        createParticles();
        setupSearchSuggestions();
        renderCards(colleges);
        applyFilters();
        loadBookings();
        
        // Show welcome notification
        showNotification('Welcome to College Saathi! 🎓', 'success');
      }, 1000);
    });
  </script>
</body>
</html>
