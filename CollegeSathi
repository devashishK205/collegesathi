    // Filters
    function applyFilters(){
      const q = $("#searchInput").value.trim().toLowerCase();
      const loc = $("#fLocation").value.trim().toLowerCase();
      const stream = $("#fStream").value;
      const minR = Number($("#fRating").value || 0);
      const maxF = Number($("#fFees").value || Infinity);
      const sort = $("#sortBy").value;

      // category chips
      const activeCats = $$("[data-cat].active").map(x=> x.dataset.cat);

      let list = colleges.filter(c=>{
        const okSearch = !q || c.name.toLowerCase().includes(q);
        const okLoc = !loc || c.location.toLowerCase().includes(loc);
        const okStream = !stream || c.stream === stream;
        const okRating = c.rating >= minR;
        const okFees = c.fees <= maxF;
        const okCat = activeCats.length ? activeCats.includes(c.stream) : true;
        return okSearch && okLoc && okStream && okRating && okFees && okCat;
      });

      // sorting
      if(sort === 'rating_desc') list.sort((a,b)=> b.rating - a.rating);
      else if(sort === 'fees_asc') list.sort((a,b)=> a.fees - b.fees);
      else if(sort === 'name_asc') list.sort((a,b)=> a.name.localeCompare(b.name));

      // empty state
      const empty = $("#emptyMsg");
      if(list.length === 0){ empty.classList.remove('hidden'); } else { empty.classList.add('hidden'); }

      // Update active filters display
      updateActiveFilters();

      renderCards(list);
    }

